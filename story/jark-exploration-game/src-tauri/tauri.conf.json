{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jark The Silent Vein",
  "version": "0.1.0",
  "identifier": "com.susulliang.human.jark",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Jark: The Silent Vein",
        "width": 1180,
        "height": 760,
        "minWidth": 360,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
